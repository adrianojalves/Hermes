<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:h="http://java.sun.com/jsf/html"
    xmlns:ui="http://java.sun.com/jsf/facelets"
    xmlns:f="http://java.sun.com/jsf/core"
    xmlns:p="http://primefaces.org/ui">
    <h:head>	
    	<link rel="icon" type="image/x-icon" href="#{resource['ajasoftware/images/favicon.ico']}"/>
    	<f:facet name="first">
			<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
			<meta name="viewport" content="width=device-width, initial-scale=1" />
		</f:facet>
        
        <title>.::Login::.</title>

        <h:outputStylesheet library="ajasoftware" name="styles/custom.css" />
		<h:outputStylesheet library="ajasoftware" name="styles/layout.css" />
		<h:outputStylesheet library="ajasoftware" name="styles/components.css" />
		<style>	
			body{
				background-color: #ede7e7;
			}
			.img{
				height: 50%;
				width: 50%;
				margin: auto;
				margin-top: 10px;
			}		
			@MEDIA (max-width: 900px) and (min-width: 640px){
				input{
					margin-left: 20px !important;					
				}
			}
			.fluid{
				width: 35%;
				margin: auto;
				margin-top: 10%;
			}
			@media(max-width: 641px){
				.fluid{
					width: 70%;
					margin: auto;
					margin-top: 10%;
				}
				.margem-botao{
					margin-left:25%;
				}
			}
			@media(min-width: 641px){
				.margem-esquerda{
					margin-left:25% !important;
				}
				.margem-botao{
					margin-left:50%;
				}
			}
			
			img{
				display: block;
				margin: auto;
				margin-top: 20px;
				width: 35%;
				height: 50%;
			}
			.labelsis{
				font-weight: bold;
				font-size: 1.5em;
				margin-left: 20px;
				margin-bottom: 5px;
				color: #BC8623;
			}
			
		</style>
    </h:head>
    <h:body>
    	<f:metadata>
    		<f:viewParam name="dummy" />
    		<f:event listener="#{loginBean.preRender}" type="preRenderView" />
    	</f:metadata>
    	
    	<div class="img">
    		<h:graphicImage library="ajasoftware" name="images/principal.png" />
    	</div>
    	
    	<div id="login-dialog" class="fluid">    		
    		
    		<h:form id="frm" prependId="false">
    			
    			<p:messages id="messages" autoUpdate="true" closable="true" />
    			
    			<p:outputLabel styleClass="labelsis" value="Hermes - Controle Interno" />
    			<p:panelGrid columns="1" styleClass="grid-login" layout="grid"
    			columnClasses="ui-grid-col-8" style="margin-bottom: 5px" >
    				<p:outputLabel value="Login" styleClass="margem-esquerda">
    					<p:inputText style="width: 100%;" styleClass="margem-esquerda" id="username"  value="#{loginBean.login}" />
    				</p:outputLabel>
    				
    				
    				<p:outputLabel value="Senha" styleClass="margem-esquerda">
    					<p:password style="width: 100%" styleClass="margem-esquerda" id="password" />
    				</p:outputLabel>    				
    				
    				<h:panelGroup/>
    				<p:commandButton styleClass="margem-botao" style="width:100px; height:40px; font-weight: bold;" value="Login" action="#{loginBean.login}" ajax="false" />
    			</p:panelGrid>
    		</h:form>
    	</div>    	
    </h:body>
    <script>    	
	
	</script>
</html>