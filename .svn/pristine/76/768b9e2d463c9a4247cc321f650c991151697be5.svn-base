<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
	xmlns:h="http://xmlns.jcp.org/jsf/html"
	xmlns:f="http://xmlns.jcp.org/jsf/core"
	xmlns:p="http://primefaces.org/ui" xmlns:o="http://omnifaces.org/ui"
	xmlns:ui="http://xmlns.jcp.org/jsf/facelets">
<f:metadata>
	<f:viewAction action="#{pesquisaClientesBean.inicializar}"></f:viewAction>
</f:metadata>
<h:head>

	<title>Pesquisa de Clientes</title>

	<h:outputStylesheet library="ajasoftware" name="styles/custom.css" />
	<h:outputStylesheet library="ajasoftware" name="styles/icons.css" />
	<h:outputStylesheet library="ajasoftware" name="styles/layout.css" />
	<h:outputStylesheet library="ajasoftware" name="styles/components.css" />

	<h:outputScript target="body" library="primefaces"
		name="jquery/jquery.js" />
</h:head>

<h:body>

	<h:form>
		<p:toolbar style="">

			<p:toolbarGroup>
				<p:commandButton process="@this painel" icon="fa fa-search"
					value="Pesquisar" update="tabela" />
			</p:toolbarGroup>

			<p:toolbarGroup styleClass="botoes-cadastro" align="right">
			</p:toolbarGroup>

		</p:toolbar>

		<p:panelGrid styleClass="remove-borda" layout="grid" columns="2"
			id="painel" style="margin-top: 5px"
			columnClasses="ui-grid-col-5, ui-grid-col-5">

			<p:outputLabel value="Nome">
				<p:inputText styleClass="campo100"
					value="#{pesquisaClientesBean.filtro.nome}" />
			</p:outputLabel>

		</p:panelGrid>

		<p:dataTable value="#{pesquisaClientesBean.model}" reflow="true"
			style="margin-top:15px" id="tabela"
			emptyMessage="Nenhum cliente encontrado." rows="20" paginator="true"
			paginatorAlwaysVisible="false" lazy="true" var="objeto"
			selection="#{pesquisaClientesBean.cliente}" rowKey="#{objeto.id}"
			styleClass="tabela">

			<f:facet name="header" style="font-size: 1.2em">
            			Lista de Clientes
			        </f:facet>

			<p:column width="35" headerText="Id" sortBy="#{objeto.id}"
				styleClass="direita">
				<h:outputText value="#{objeto.id}" />
			</p:column>

			<p:column headerText="Nome" sortBy="#{objeto.nome}">
				<h:outputText value="#{objeto.nome}" />
			</p:column>

			<p:column headerText="Cidade" styleClass="centro">
				<h:outputText value="#{objeto.cidade}" />
			</p:column>

			<p:column styleClass="centro" headerText="" width="40">
				<p:panelGrid columns="1" layout="grid" class="coluna-tabela">
					<p:commandButton icon="fa fa-check-circle" title="Selecionar"
						process="@this"
						action="#{pesquisaClientesBean.selecionar}">
						<f:setPropertyActionListener
									target="#{pesquisaClientesBean.cliente}"
									value="#{objeto}" />
					</p:commandButton>

				</p:panelGrid>
			</p:column>
		</p:dataTable>
	</h:form>

</h:body>

</html>